# ---- .NET ----
bin/
obj/
out/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
*.userosscache
*.dbmdl
.vs/
project.lock.json
artifacts/
TestResults/
*.trx
*.coverage
*.coveragexml
coverage/
[Tt]est[Rr]esults/

# ---- EF Core / local data ----
*.db
*.db-shm
*.db-wal

# ---- Secrets / config (never commit) ----
*.env
.env.*
!.env.example
appsettings.*.local.json
secrets.json
*.pfx
*.key
*.pem

# ---- IaC (state + tfvars/inventory can hold secrets or your IP) ----
infra/terraform/.terraform/
# .terraform.lock.hcl IS committed (pins provider versions + multi-platform hashes).
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Terraform remote-state backend coordinates (names the state storage account); .example is committed.
infra/terraform/backend.hcl
infra/ansible/inventory.ini
infra/ansible/.vault_pass
infra/ansible/group_vars/all.yml
# SSH keys must never be committed — generate them OUTSIDE the repo (~/.ssh). Defensive backstop
# alongside gitleaks, in case a key gets created inside the tree by accident.
*_deploy_key
*_deploy_key.pub
id_ed25519*
id_rsa*
*.pem

# ---- Angular / Node (frontend/) ----
node_modules/
dist/
.angular/
.npm/
npm-debug.log*
yarn-error.log*
*.tsbuildinfo
.eslintcache

# ---- Docker / infra local state ----
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
*.retry

# ---- IDE / editor ----
.idea/
*.swp
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Build-time OpenAPI document (Microsoft.Extensions.ApiDescription.Server) ----
# Generated on every `dotnet build` into artifacts/. Gitignored until the contract is
# hardened and a canonical committed location is chosen (docs/openapi-contract-plan.md, Phases 2-5).
/artifacts/
