{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "RateLimiting": {
    "PermitLimit": 120,
    "WindowSeconds": 60
  },
  "AllowedHosts": "*"
}
