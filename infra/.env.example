# Production environment for docker-compose.prod.yml — copy to .env and fill in.
# NEVER commit the real .env (it is gitignored). Generate strong secrets, e.g.:
#   openssl rand -base64 24

# --- Container images (prebuilt in CI, pulled from GHCR — ADR 0012) ---
# GHCR_OWNER: the GitHub owner that owns the packages, lowercase (e.g. dezoxy).
# COMPANYOPS_VERSION: the release version to run, e.g. 1.2.3 (the release tag without the 'v').
GHCR_OWNER=dezoxy
COMPANYOPS_VERSION=latest

# --- Public hostnames (must resolve to this host's public IP for Let's Encrypt TLS) ---
APP_DOMAIN=app.example.com
KEYCLOAK_DOMAIN=auth.example.com
ACME_EMAIL=admin@example.com

# --- Datastore secrets (no single quotes in KC_DB_PASSWORD — it's used in an init SQL string) ---
POSTGRES_PASSWORD=
KC_DB_PASSWORD=
RABBITMQ_PASSWORD=

# --- Keycloak bootstrap admin (prefer a non-default username; create real users via the
#     admin console after first boot) ---
KC_ADMIN_USER=kcadmin
KC_ADMIN_PASSWORD=

# --- Optional: external-system base URLs (empty -> the bundled fakeexternals mock) ---
FINANCE_BASE_URL=
INVENTORY_BASE_URL=

# --- Optional: OpenTelemetry collector OTLP endpoint (leave empty to disable export) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
